# Reference: <https://postmarketos.org/kernelpkg>
# Maintainer: Your Name <your@email.com>

pkgname=linux-samsung-gta4l
pkgver=4.19.325
pkgrel=0
pkgdesc="Samsung Galaxy Tab A7 LTE kernel (SM-T505/N/C/T507)"
arch="aarch64"
_carch="arm64"
_flavor="samsung-gta4l"
url="https://github.com/LineageOS/android_kernel_samsung_sm6115"
license="GPL-2.0-only"
options="!strip !check !tracedeps pmb:cross-native"

# Kernel source
_repository="android_kernel_samsung_sm6115"
_commit="lineage-21"
source="
	$pkgname-$pkgver.tar.gz::https://github.com/LineageOS/$_repository/archive/refs/heads/$_commit.tar.gz
	config-$_flavor.$_carch
	0001-fix-gcc-compatibility.patch
"
builddir="$srcdir/${_repository}-${_commit}"

prepare() {
	default_prepare
	cp "$srcdir/config-$_flavor.$_carch" .config
}

build() {
	unset LDFLAGS
	make O="$builddir" \
		ARCH="$_carch" \
		CC="${CC:-gcc}" \
		KBUILD_BUILD_VERSION="$((pkgrel + 1 ))-postmarketOS"
}

package() {
	# Install kernel image
	install -Dm644 "$builddir/arch/$_carch/boot/Image.gz" \
		"$pkgdir/boot/vmlinuz"

	# Install DTBs
	install -Dm644 "$builddir/arch/$_carch/boot/dts/qcom/sm6115-samsung-gta4l.dtb" \
		"$pkgdir/boot/dtbs/qcom/sm6115-samsung-gta4l.dtb"

	# Install modules
	make O="$builddir" \
		ARCH="$_carch" \
		INSTALL_MOD_PATH="$pkgdir" \
		INSTALL_MOD_STRIP=1 \
		modules_install

	rm -f "$pkgdir/lib/modules/*/build" "$pkgdir/lib/modules/*/source"
}
