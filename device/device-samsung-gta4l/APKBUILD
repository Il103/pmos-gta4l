# Reference: <https://postmarketos.org/devicepkg>
# Maintainer: Your Name <your@email.com>
# Co-Maintainer: Ahmed, Omar

pkgname=device-samsung-gta4l
pkgdesc="Samsung Galaxy Tab A7 LTE (SM-T505/N/C/T507)"
pkgver=2
pkgrel=0
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
depends="
	postmarketos-base
	linux-samsung-gta4l
	soc-qcom-sm6115
	soc-qcom-sm6115-modem
	alsa-ucm-conf
"
makedepends="devicepkg-dev"
subpackages="
	$pkgname-nonfree-firmware:nonfree_firmware
	$pkgname-phosh:phosh
"
source="
	deviceinfo
	modules-initfs
	90-feedbackd.rules
	phosh/
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname
}

nonfree_firmware() {
	pkgdesc="Samsung Galaxy Tab A7 LTE firmware (WiFi, BT, modem)"
	depends="firmware-samsung-gta4l"
	mkdir "$subpkgdir"
}

phosh() {
	pkgdesc="PostmarketOS Phosh config for gta4l"
	install_if="$pkgname=$pkgver-r$pkgrel postmarketos-ui-phosh"
	install -Dm644 "$srcdir/phosh/phoc.ini" \
		"$subpkgdir/etc/phosh/phoc.ini"
}
